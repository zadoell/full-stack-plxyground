# ========== BACKEND ==========
PORT=3011
DB_PROVIDER=sqlite
DATABASE_URL=./plxyground.db
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:19006,http://localhost:3012

# Media hosting (S3/Cloudinary) – optional; seeds use curated Unsplash URLs as fallback
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# CLOUDINARY_URL=

# Email provider – set LOCAL_STUB_EMAIL=true to log emails to console
LOCAL_STUB_EMAIL=true
# RESEND_API_KEY=
# SES_REGION=

# Mock toggles
MOCK_ANALYTICS=false
ADMIN_AUTO_REFRESH_INTERVAL=30000

# ========== FRONTEND (Expo) ==========
EXPO_PUBLIC_API_BASE_URL=http://localhost:3011

# ========== ADMIN PANEL ==========
API_BASE_URL=http://localhost:3011
